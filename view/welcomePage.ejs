<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ConnectHub — Connect. Collaborate. Grow Together.</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/wlc.css">
</head>
<body>

    <div id="carouselExampleCaptions" class="carousel slide wlc-carousel" data-bs-ride="false">

        <div class="carousel-indicators">
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>

        <div class="carousel-inner">

            <!-- Slide 1 -->
            <div class="carousel-item active">
                <div class="slide-frame">
                    <div class="slide-media">
                        <img src="/images/image_1.png" class="d-block w-100" alt="Professionals collaborating around a table">
                        <div class="media-fade"></div>
                    </div>
                    <div class="slide-panel">
                        <div class="node-mesh" aria-hidden="true">
                            <svg viewBox="0 0 400 400" preserveAspectRatio="xMidYMid slice">
                                <line x1="40" y1="60" x2="140" y2="120" class="mesh-line"></line>
                                <line x1="140" y1="120" x2="120" y2="230" class="mesh-line"></line>
                                <line x1="140" y1="120" x2="260" y2="90" class="mesh-line"></line>
                                <line x1="260" y1="90" x2="340" y2="180" class="mesh-line"></line>
                                <line x1="120" y1="230" x2="240" y2="280" class="mesh-line"></line>
                                <line x1="240" y1="280" x2="340" y2="180" class="mesh-line"></line>
                                <line x1="240" y1="280" x2="180" y2="360" class="mesh-line"></line>
                                <circle cx="40" cy="60" r="4" class="mesh-node"></circle>
                                <circle cx="140" cy="120" r="5" class="mesh-node"></circle>
                                <circle cx="260" cy="90" r="4" class="mesh-node"></circle>
                                <circle cx="120" cy="230" r="4" class="mesh-node"></circle>
                                <circle cx="340" cy="180" r="5" class="mesh-node"></circle>
                                <circle cx="240" cy="280" r="4" class="mesh-node"></circle>
                                <circle cx="180" cy="360" r="4" class="mesh-node"></circle>
                            </svg>
                        </div>
                        <div class="panel-content">
                            <p class="eyebrow">ConnectHub</p>
                            <h5 class="slide-title">
                                Connect. Collaborate.<br>
                                <span class="accent">Grow Together.</span>
                            </h5>
                            <p class="slide-copy">The platform where professional workers connect, collaborate, and create opportunities.</p>
                            <div class="wrap-btn">
                                <button class="next-btn">Next</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Slide 2 -->
            <div class="carousel-item">
                <div class="slide-frame">
                    <div class="slide-media">
                        <img src="/images/image_2.png" class="d-block w-100" alt="Professional reviewing work on a laptop in the city">
                        <div class="media-fade"></div>
                    </div>
                    <div class="slide-panel">
                        <div class="node-mesh" aria-hidden="true">
                            <svg viewBox="0 0 400 400" preserveAspectRatio="xMidYMid slice">
                                <line x1="60" y1="50" x2="160" y2="100" class="mesh-line"></line>
                                <line x1="160" y1="100" x2="280" y2="60" class="mesh-line"></line>
                                <line x1="160" y1="100" x2="150" y2="220" class="mesh-line"></line>
                                <line x1="280" y1="60" x2="350" y2="160" class="mesh-line"></line>
                                <line x1="150" y1="220" x2="260" y2="260" class="mesh-line"></line>
                                <line x1="260" y1="260" x2="350" y2="160" class="mesh-line"></line>
                                <line x1="150" y1="220" x2="100" y2="330" class="mesh-line"></line>
                                <circle cx="60" cy="50" r="4" class="mesh-node"></circle>
                                <circle cx="160" cy="100" r="5" class="mesh-node"></circle>
                                <circle cx="280" cy="60" r="4" class="mesh-node"></circle>
                                <circle cx="350" cy="160" r="5" class="mesh-node"></circle>
                                <circle cx="150" cy="220" r="4" class="mesh-node"></circle>
                                <circle cx="260" cy="260" r="4" class="mesh-node"></circle>
                                <circle cx="100" cy="330" r="4" class="mesh-node"></circle>
                            </svg>
                        </div>
                        <div class="panel-content">
                            <p class="eyebrow">ConnectHub</p>
                            <h5 class="slide-title">
                                Find People. Share Skills.<br>
                                <span class="accent">Build Your Network.</span>
                            </h5>
                            <p class="slide-copy">Discover talented professionals, share expertise, and unlock new opportunities.</p>
                            <div class="wrap-btn">
                                <button class="next-btn">Next</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Slide 3 -->
            <div class="carousel-item">
                <div class="slide-frame">
                    <div class="slide-media">
                        <img src="/images/image_3.png" class="d-block w-100" alt="Team of professionals working together and smiling">
                        <div class="media-fade"></div>
                    </div>
                    <div class="slide-panel">
                        <div class="node-mesh" aria-hidden="true">
                            <svg viewBox="0 0 400 400" preserveAspectRatio="xMidYMid slice">
                                <line x1="50" y1="70" x2="150" y2="110" class="mesh-line"></line>
                                <line x1="150" y1="110" x2="270" y2="80" class="mesh-line"></line>
                                <line x1="150" y1="110" x2="130" y2="240" class="mesh-line"></line>
                                <line x1="270" y1="80" x2="345" y2="190" class="mesh-line"></line>
                                <line x1="130" y1="240" x2="250" y2="270" class="mesh-line"></line>
                                <line x1="250" y1="270" x2="345" y2="190" class="mesh-line"></line>
                                <line x1="130" y1="240" x2="190" y2="350" class="mesh-line"></line>
                                <circle cx="50" cy="70" r="4" class="mesh-node"></circle>
                                <circle cx="150" cy="110" r="5" class="mesh-node"></circle>
                                <circle cx="270" cy="80" r="4" class="mesh-node"></circle>
                                <circle cx="345" cy="190" r="5" class="mesh-node"></circle>
                                <circle cx="130" cy="240" r="4" class="mesh-node"></circle>
                                <circle cx="250" cy="270" r="4" class="mesh-node"></circle>
                                <circle cx="190" cy="350" r="4" class="mesh-node"></circle>
                            </svg>
                        </div>
                        <div class="panel-content">
                            <p class="eyebrow">ConnectHub</p>
                            <h5 class="slide-title">
                                Join a Community of<br>
                                <span class="accent">Professionals.</span>
                            </h5>
                            <p class="slide-copy">Register today and start your journey towards growth and success.</p>
                            <div class="wrap-btn">
                                <a href="/user/registration/page" class="reg-link"><button class="reg-btn">Register Now</button></a>
                                <p class="or-divider">OR</p>
                                <a href="/user/login/page" class="log-link"><button class="log-btn">Login</button></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleCaptions" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </div>

    <script src="/bootstrap/js/bootstrap.bundle.js"></script>
    <script src="/js/wlc.js"></script>
</body>
</html>
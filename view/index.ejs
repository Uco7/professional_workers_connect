<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Online Professional Workers Connect</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/style.css">

    <script src="https://kit.fontawesome.com/56adb67a5b.js" crossorigin="anonymous"></script>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
        <div class="container">
            <a href="/" class="navbar-brand text-uppercase fw-bold">
                <img src="/images/logo.png" alt="logo" onerror="this.style.display='none'"> Connect<span class="brand-accent">Pro</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#list1" aria-controls="list1" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="list1">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item">
                        <a href="/about" class="nav-link">About Us</a>
                    </li>
                    <li class="nav-item">
                        <a href="/contact" class="nav-link">Contact Us</a>
                    </li>

                    <% if (user && user._id) { %>
                        <li class="nav-item">
                        </li>
                        <li class="nav-item">
                            <a href="/vendor/register/profession?id=<%= user._id %>" class="nav-link reg">Register Now</a>
                        </li>
                        <li class="nav-item">
                        </li>
                    <% } else { %>
                        <li class="nav-item">
                            <a href="/login" class="nav-link reg">Register Now</a>
                        </li>
                        <li class="nav-item">
                            <a href="/login" class="nav-link">Login</a>
                        </li>
                    <% } %>

                    <li class="nav-item">
                             <a href="/logout" class="  nav-link sub">Logout</a>

                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <div id="carouselExampleAutoplaying" class="carousel slide hero-carousel" data-bs-ride="carousel">
        <div class="carousel-inner">
            <div class="carousel-item active">
                <img src="/images/capinter.jpg" class="d-block w-100" alt="Carpentry services">
                <div class="hero-fade"></div>
                <div class="hero-caption">
                    <p class="eyebrow">ConnectPro</p>
                    <% if (user && user._id) { %>
                        <h1>Welcome back,<br><span class="accent"><%= user.fName %>.</span></h1>
                    <% } else { %>
                        <h1>Trusted pros,<br><span class="accent">one tap away.</span></h1>
                    <% } %>
                    <p class="lead-copy">Find verified local vendors for every job, big or small.</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="/images/woodwork.jpeg" class="d-block w-100" alt="Woodwork services">
                <div class="hero-fade"></div>
                <div class="hero-caption">
                    <p class="eyebrow">ConnectPro</p>
                    <h1>Skilled hands,<br><span class="accent">ready to work.</span></h1>
                    <p class="lead-copy">From woodwork to wiring, our network has you covered.</p>
                </div>
            </div>
            <div class="carousel-item">
                <img src="/images/carrepia.jpeg" class="d-block w-100" alt="Auto repair services">
                <div class="hero-fade"></div>
                <div class="hero-caption">
                    <p class="eyebrow">ConnectPro</p>
                    <h1>Book a vendor<br><span class="accent">in minutes.</span></h1>
                    <p class="lead-copy">Compare ratings, message vendors, and book with confidence.</p>
                </div>
            </div>
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleAutoplaying" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleAutoplaying" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#carouselExampleAutoplaying" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
            <button type="button" data-bs-target="#carouselExampleAutoplaying" data-bs-slide-to="1" aria-label="Slide 2"></button>
            <button type="button" data-bs-target="#carouselExampleAutoplaying" data-bs-slide-to="2" aria-label="Slide 3"></button>
        </div>
    </div>

    <div class="container services-intro">
        <div class="intro-txt text-center">
            <h2 id="buy"></h2>
            <div class="container mt-4 vendor-callout">
                <h4>Already a Vendor?</h4>
                <span>Upload past and recent works now
                    <a href="#" class="link-amber" data-bs-toggle="modal" data-bs-target="#emailModal">Click Here</a>
                </span>
            </div>
        </div>

        <div class="modal fade" id="emailModal" tabindex="-1" aria-labelledby="emailModalLabel" aria-hidden="true">
            <div class="modal-dialog" role="document">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="emailModalLabel">Enter Your Email</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form id="emailForm" action="/find/vendor/by/email" method="post">
                            <div class="mb-3">
                                <label for="emailInput" class="form-label">Email address</label>
                                <input type="email" class="form-control" id="emailInput" name="email" placeholder="Enter your email" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Submit</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="intro-text text-center">
            <p>Pick a service from the list below, and we'll connect you with a trusted vendor near you.</p>
        </div>
    </div>

    <div class="container categories">
        <div class="title text-center">
            <p class="eyebrow text-center">Browse by trade</p>
            <h4>Categories</h4>
        </div>
        <div class="wrap-boxes">
            <div class="box1">
                <div class="icon text-center"><i class="fa-solid fa-computer"></i></div>
                <div class="text-center">Computer Engineers</div>
            </div>
            <div class="box1">
                <div class="icon text-center"><i class="fa-solid fa-house-flood-water"></i></div>
                <div class="text-center">Home Appliances</div>
            </div>
            <div class="box1">
                <div class="icon text-center"><i class="fa-solid fa-bath"></i></div>
                <div class="text-center">Plumbers</div>
            </div>
            <div class="box1">
                <div class="icon text-center"><i class="fa-solid fa-mobile"></i></div>
                <div class="text-center">ICT</div>
            </div>
            <div class="box1 box-orange">
                <div class="icon text-center"><i class="fa-solid fa-plug"></i></div>
                <div class="text-center">Electrical Engineers</div>
            </div>
            <div class="box1 box-orange">
                <div class="icon text-center"><i class="fa-solid fa-screwdriver"></i></div>
                <div class="text-center">Mechanical Engineers</div>
            </div>
            <div class="box1 box-orange">
                <div class="icon text-center"><i class="fa-solid fa-couch"></i></div>
                <div class="text-center">Wood Work<br>Engineers</div>
            </div>
            <div class="box1 box-red">
                <div class="icon text-center"><i class="fa-solid fa-shirt"></i></div>
                <div class="text-center">Furniture</div>
            </div>
        </div>
    </div>

    <section class="container">
        <div class="top-provider">
            <div class="text-center">
                <p class="eyebrow text-center">Highly rated</p>
                <h4>Top providers near you</h4>
            </div>
            <div class="provider-box wrap-boxes">

                <!-- Populated dynamically; placeholder card structure kept below for reference -->
                <!-- <div class="box-content placeholder-card" aria-hidden="true">
                    <div class="image-div text-center">
                        <img src="/images/avatar-placeholder.png" alt="" onerror="this.style.visibility='hidden'">
                    </div>
                    <div class="star-icon text-center">
                        <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-regular fa-star"></i>
                    </div>
                    <div class="text-center provider-name">Vendor Name</div>
                    <div class="text-center provider-trade">Trade / Specialty</div>
                    <div class="image-txt text-center">
                        <span class="book"><a href="#">Book Now</a></span>
                    </div>
                </div> -->
                

                <% if (vendors && vendors.length > 0) { %>
    <% vendors.forEach(function(vendor) { %>
        <div class="box-content">
            <div class="image-div text-center">
                <% if (vendor.profileImage && vendor.imageType) { %>
                    <img src="data:<%= vendor.imageType %>;base64,<%= vendor.profileImage %>" alt="<%= vendor.userRef.fName %>">
                <% } else { %>
                    <img src="/images/avatar-placeholder.png" alt="" onerror="this.style.visibility='hidden'">
                <% } %>
            </div>
            <div class="star-icon text-center">
                <% var rating = (vendorRatings && vendorRatings[vendor._id]) ? vendorRatings[vendor._id] : 0; %>
                <% for (var i = 1; i <= 5; i++) { %>
                    <% if (i <= rating) { %>
                        <i class="fa-solid fa-star"></i>
                    <% } else { %>
                        <i class="fa-regular fa-star"></i>
                    <% } %>
                <% } %>
            </div>
            <div class="text-center provider-name"><%= vendor.userRef.fName %> <%= vendor.userRef.lName %></div>
            <div class="text-center provider-trade"><%= vendor.userRefs.job_title %></div>
            <div class="image-txt text-center">
                <span class="book"><a href="/clients/book/vendor/page?id=<%= vendor._id %>&userId=<%= user ? user._id : '' %>">Book Now</a></span>
            </div>
        </div>
    <% }); %>
<% } else { %>
    <div class="box-content placeholder-card" aria-hidden="true">
        <div class="image-div text-center">
            <img src="/images/avatar-placeholder.png" alt="" onerror="this.style.visibility='hidden'">
        </div>
        <div class="star-icon text-center">
            <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-regular fa-star"></i>
        </div>
        <div class="text-center provider-name">Vendor Name</div>
        <div class="text-center provider-trade">Trade / Specialty</div>
        <div class="image-txt text-center">
            <span class="book"><a href="#">Book Now</a></span>
        </div>
    </div>
<% } %>

            </div>
        </div>
    </section>

    <div class="container text-center sell">
        <img src="/images/reg.jpg" alt="">
    </div>

    <article class="container sell-service">
        <h5>Sell Your Service</h5>
        <div class="service-txt">
            <p>You can sell your services here — register your gig or expertise and</p>
            <div>get verified on our website, and let us do the job of connecting you</div>
            <div>with a growing community of clients and customers on Online Professional Workers Connect.</div>
        </div>
        <% if (user && user._id) { %>
            <button class="btn-div"><a href="/vendor/register/profession?id=<%= user._id %>">Register As Vendor</a></button>
        <% } else { %>
            <button class="btn-div"><a href="/login">Register As Vendor</a></button>
        <% } %>
    </article>

    <section class="summary">
        <div class="container">
            <div class="cont">
                <div class="about-summary ab-sum">
                    <h6>About Us</h6>
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/about">About Us</a></li>
                        <li><a href="/blog">Blog</a></li>
                        <li><a href="/careers">Work With Us</a></li>
                        <li><a href="/terms">Terms &amp; Conditions</a></li>
                    </ul>
                </div>
                <div class="about-summary services">
                    <h6>Services</h6>
                    <ul>
                        <li><a href="#">Search Terms</a></li>
                        <li><a href="#">Advance Search</a></li>
                        <li><a href="/privacy">Privacy &amp; Policy</a></li>
                        <li><a href="/support">Support Us</a></li>
                        <li><a href="#">Our Stores</a></li>
                    </ul>
                </div>
                <div class="about-summary contact">
                    <h6>Contact Us</h6>
                    <ul>
                        <li><i class="fa-solid fa-phone"></i> <a href="tel:+123">+123 Ikwo Street</a></li>
                        <li><i class="fa-solid fa-envelope"></i> <a href="mailto:support@gmail.com">support@gmail.com</a></li>
                        <li><i class="fa-solid fa-headset"></i> <a href="#">+123 Customer Care</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="footer">
        <footer class="copy">&copy; 2024 ConnectPro. All rights reserved.</footer>
        <div class="footer-icon">
            <a href="#" aria-label="Facebook"><i class="fa-brands fa-facebook"></i></a>
            <a href="#" aria-label="Twitter"><i class="fa-brands fa-twitter"></i></a>
            <a href="#" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
        </div>
    </section>

    <script>
        window.addEventListener("load", function () {
            typeWriter();
        });
        var i = 0;
        var txt = "What are you buying today?";
        var speed = 70;
        function typeWriter() {
            var el = document.getElementById("buy");
            if (i < txt.length && el) {
                el.innerHTML += txt.charAt(i);
                i++;
                setTimeout(typeWriter, speed);
            }
        }
    </script>

    <script src="/bootstrap/js/bootstrap.bundle.js"></script>
</body>
</html>